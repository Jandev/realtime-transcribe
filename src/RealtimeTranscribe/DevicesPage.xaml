<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RealtimeTranscribe.DevicesPage"
    x:Name="DevicesPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RealtimeTranscribe.ViewModels"
    Title="Devices">

    <ScrollView>
        <VerticalStackLayout
            Padding="20,16"
            Spacing="0">

            <!-- ── Refresh ────────────────────────────────────────────── -->
            <HorizontalStackLayout
                HorizontalOptions="End"
                Margin="0,0,0,16">
                <Button
                    Command="{Binding RefreshDevicesCommand}"
                    Text="Refresh"
                    Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

            <!-- Status message (e.g. "Input: Built-in Microphone") -->
            <Label
                HorizontalOptions="Center"
                Margin="0,0,0,24"
                FontSize="13"
                Text="{Binding StatusMessage}"
                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <!-- ── Input Devices ──────────────────────────────────────── -->
            <Label
                Style="{StaticResource SectionHeader}"
                Text="INPUT DEVICES"
                Margin="4,0,0,6" />

            <Label
                FontSize="13"
                Margin="4,0,0,8"
                Text="Select the microphone or audio input source to record from."
                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}" />

            <Border Margin="0,0,0,24">
                <ScrollView
                    MinimumHeightRequest="220"
                    MaximumHeightRequest="440">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding InputDevices}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectableAudioDevice">
                                <Grid
                                    ColumnDefinitions="32,*"
                                    Padding="16,12"
                                    MinimumHeightRequest="44">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference DevicesPageRoot}, Path=BindingContext.SelectInputDeviceCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <!-- Checkmark (selected indicator) -->
                                    <Label
                                        Grid.Column="0"
                                        FontSize="17"
                                        Text="✓"
                                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        IsVisible="{Binding IsSelected}" />
                                    <!-- Device name -->
                                    <Label
                                        Grid.Column="1"
                                        FontSize="17"
                                        Text="{Binding Device.Name}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                        <Label
                            Margin="16,12"
                            FontSize="15"
                            IsVisible="{Binding Source={x:Reference DevicesPageRoot}, Path=BindingContext.HasNoInputDevices}"
                            Text="No input devices found. Tap Refresh to scan again."
                            TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <!-- ── Output Devices ─────────────────────────────────────── -->
            <Label
                Style="{StaticResource SectionHeader}"
                Text="OUTPUT DEVICES"
                Margin="4,0,0,6" />

            <Label
                FontSize="13"
                Margin="4,0,0,8"
                Text="The currently active audio output. To record system audio, configure a loopback device (e.g. BlackHole) in macOS Audio MIDI Setup."
                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}" />

            <Border Margin="0,0,0,32">
                <ScrollView
                    MinimumHeightRequest="220"
                    MaximumHeightRequest="440">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding OutputDevices}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectableAudioDevice">
                                <Grid
                                    ColumnDefinitions="32,*"
                                    Padding="16,12"
                                    MinimumHeightRequest="44">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference DevicesPageRoot}, Path=BindingContext.SelectOutputDeviceCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label
                                        Grid.Column="0"
                                        FontSize="17"
                                        Text="✓"
                                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center"
                                        IsVisible="{Binding IsSelected}" />
                                    <Label
                                        Grid.Column="1"
                                        FontSize="17"
                                        Text="{Binding Device.Name}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                        <Label
                            Margin="16,12"
                            FontSize="15"
                            IsVisible="{Binding Source={x:Reference DevicesPageRoot}, Path=BindingContext.HasNoOutputDevices}"
                            Text="No output devices found. Tap Refresh to scan again."
                            TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}" />
                    </VerticalStackLayout>
                </ScrollView>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

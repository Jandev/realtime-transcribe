<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RealtimeTranscribe.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RealtimeTranscribe.ViewModels"
    Title="Realtime Transcribe">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,16"
            Spacing="16">

            <!-- Status label -->
            <Label
                HorizontalOptions="Center"
                Text="{Binding StatusMessage}"
                TextColor="{StaticResource Secondary}" />

            <!-- Record / Stop button -->
            <Button
                Command="{Binding ToggleRecordingCommand}"
                FontSize="18"
                HeightRequest="60"
                HorizontalOptions="Fill"
                Text="{Binding RecordButtonText}"
                BackgroundColor="{Binding IsRecording, Converter={StaticResource BoolToRecordColorConverter}}" />

            <!-- Cancel button (visible while processing) -->
            <Button
                Command="{Binding CancelCommand}"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsProcessing}"
                Text="✕  Cancel"
                Style="{StaticResource SecondaryButton}" />

            <!-- Font size controls -->
            <HorizontalStackLayout
                HorizontalOptions="End"
                Spacing="8">
                <Button
                    Command="{Binding DecreaseFontSizeCommand}"
                    Text="A−"
                    FontSize="13"
                    Padding="10,6"
                    MinimumWidthRequest="44"
                    Style="{StaticResource SecondaryButton}"
                    ToolTipProperties.Text="Decrease text size" />
                <Button
                    Command="{Binding IncreaseFontSizeCommand}"
                    Text="A+"
                    FontSize="15"
                    Padding="10,6"
                    MinimumWidthRequest="44"
                    Style="{StaticResource SecondaryButton}"
                    ToolTipProperties.Text="Increase text size" />
            </HorizontalStackLayout>

            <!-- Transcript section -->
            <Label
                FontAttributes="Bold"
                FontSize="{Binding HeadingFontSize}"
                Text="Transcript" />

            <Border
                Stroke="{StaticResource Gray300}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6">
                <Editor
                    AutoSize="TextChanges"
                    FontSize="{Binding ContentFontSize}"
                    IsReadOnly="True"
                    MinimumHeightRequest="120"
                    Placeholder="Transcript will appear here after recording…"
                    Text="{Binding Transcript}" />
            </Border>

            <Button
                Command="{Binding CopyTranscriptCommand}"
                HorizontalOptions="End"
                Text="📋  Copy Transcript"
                Style="{StaticResource SecondaryButton}" />

            <!-- Summary section -->
            <Label
                FontAttributes="Bold"
                FontSize="{Binding HeadingFontSize}"
                Text="Summary &amp; Action Items" />

            <Border
                Stroke="{StaticResource Gray300}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 6">
                <WebView
                    x:Name="SummaryWebView"
                    HeightRequest="120"
                    MinimumHeightRequest="120"
                    Navigated="OnSummaryWebViewNavigated">
                    <WebView.Source>
                        <HtmlWebViewSource Html="{Binding SummaryHtml}" />
                    </WebView.Source>
                </WebView>
            </Border>

            <Button
                Command="{Binding CopySummaryCommand}"
                HorizontalOptions="End"
                Text="📋  Copy Summary"
                Style="{StaticResource SecondaryButton}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

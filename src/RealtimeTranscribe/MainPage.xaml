<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RealtimeTranscribe.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:RealtimeTranscribe.ViewModels"
    Title="Transcribe">

    <ScrollView>
        <VerticalStackLayout
            Padding="20,16"
            Spacing="0">

            <!-- ── Status ─────────────────────────────────────────────── -->
            <Label
                HorizontalOptions="Center"
                Margin="0,0,0,16"
                FontSize="13"
                Text="{Binding StatusMessage}"
                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray500}}" />

            <!-- ── Record / Stop button ───────────────────────────────── -->
            <Button
                Command="{Binding ToggleRecordingCommand}"
                FontSize="17"
                FontAttributes="Bold"
                HeightRequest="50"
                HorizontalOptions="Fill"
                Margin="0,0,0,12"
                CornerRadius="10"
                Text="{Binding RecordButtonText}"
                BackgroundColor="{Binding IsRecording, Converter={StaticResource BoolToRecordColorConverter}}" />

            <!-- ── Cancel button (visible while processing) ───────────── -->
            <Button
                Command="{Binding CancelCommand}"
                HorizontalOptions="Fill"
                Margin="0,0,0,20"
                IsVisible="{Binding IsProcessing}"
                Text="Cancel"
                Style="{StaticResource SecondaryButton}" />

            <!-- ── Transcript ─────────────────────────────────────────── -->
            <Label
                Style="{StaticResource SectionHeader}"
                Text="TRANSCRIPT"
                Margin="4,0,0,6" />

            <Border Margin="0,0,0,4">
                <Editor
                    x:Name="TranscriptEditor"
                    FontSize="{Binding ContentFontSize}"
                    IsReadOnly="True"
                    Margin="4,4"
                    HeightRequest="150"
                    Placeholder="Transcript will appear here after recording…"
                    Text="{Binding Transcript}" />
            </Border>

            <!-- Transcript actions row -->
            <HorizontalStackLayout
                Margin="0,0,0,20"
                HorizontalOptions="End"
                Spacing="8">
                <Button
                    Command="{Binding DecreaseFontSizeCommand}"
                    Text="A−"
                    FontSize="13"
                    FontAttributes="None"
                    Padding="10,6"
                    MinimumWidthRequest="44"
                    Style="{StaticResource SecondaryButton}"
                    ToolTipProperties.Text="Decrease text size" />
                <Button
                    Command="{Binding IncreaseFontSizeCommand}"
                    Text="A+"
                    FontSize="15"
                    FontAttributes="None"
                    Padding="10,6"
                    MinimumWidthRequest="44"
                    Style="{StaticResource SecondaryButton}"
                    ToolTipProperties.Text="Increase text size" />
                <Button
                    Command="{Binding CopyTranscriptCommand}"
                    Text="Copy"
                    Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

            <!-- ── Speaker-Attributed Transcript ─────────────────────── -->
            <Label
                Style="{StaticResource SectionHeader}"
                Text="SPEAKER-ATTRIBUTED TRANSCRIPT"
                Margin="4,0,0,6" />

            <Border Margin="0,0,0,4">
                <Editor
                    x:Name="DiarizedTranscriptEditor"
                    FontSize="{Binding ContentFontSize}"
                    IsReadOnly="True"
                    Margin="4,4"
                    HeightRequest="150"
                    Placeholder="Speaker-attributed transcript will appear here after recording…"
                    Text="{Binding DiarizedTranscript}" />
            </Border>

            <HorizontalStackLayout
                Margin="0,0,0,20"
                HorizontalOptions="End">
                <Button
                    Command="{Binding CopyDiarizedTranscriptCommand}"
                    Text="Copy"
                    Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

            <!-- ── Summary &amp; Action Items ─────────────────────────── -->
            <Label
                Style="{StaticResource SectionHeader}"
                Text="SUMMARY &amp; ACTION ITEMS"
                Margin="4,0,0,6" />

            <Border Margin="0,0,0,4">
                <WebView
                    x:Name="SummaryWebView"
                    HeightRequest="120"
                    MinimumHeightRequest="120"
                    Navigated="OnSummaryWebViewNavigated">
                    <WebView.Source>
                        <HtmlWebViewSource Html="{Binding SummaryHtml}" />
                    </WebView.Source>
                </WebView>
            </Border>

            <HorizontalStackLayout
                Margin="0,0,0,32"
                HorizontalOptions="End">
                <Button
                    Command="{Binding CopySummaryCommand}"
                    Text="Copy"
                    Style="{StaticResource SecondaryButton}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

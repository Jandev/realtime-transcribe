<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="RealtimeTranscribe.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,16"
            Spacing="16">

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="Azure OpenAI Configuration" />

            <Label Text="Endpoint URL" />
            <Entry
                Keyboard="Url"
                Placeholder="https://&lt;resource&gt;.openai.azure.com/"
                Text="{Binding Endpoint}" />

            <Label Text="API Key (leave blank to use DefaultAzureCredential)" />
            <Entry
                IsPassword="True"
                Placeholder="••••••••"
                Text="{Binding ApiKey}" />

            <Label Text="Whisper Deployment Name" />
            <Entry
                Placeholder="whisper-large-v3"
                Text="{Binding WhisperDeployment}" />

            <Label Text="Chat Deployment Name" />
            <Entry
                Placeholder="gpt-4o-mini"
                Text="{Binding ChatDeployment}" />

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="File Storage" />

            <Label Text="Output Folder" />
            <HorizontalStackLayout Spacing="8">
                <Entry
                    HorizontalOptions="FillAndExpand"
                    IsReadOnly="True"
                    Placeholder="No folder selected — summaries will not be saved"
                    Text="{Binding OutputFolder}" />
                <Button
                    Command="{Binding BrowseOutputFolderCommand}"
                    Text="Browse…" />
            </HorizontalStackLayout>

            <Button
                Command="{Binding SaveCommand}"
                HorizontalOptions="Fill"
                Text="Save Settings" />

            <Label
                HorizontalOptions="Center"
                Text="{Binding SaveStatus}"
                TextColor="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Apple Human Interface Guidelines — System Colors
        https://developer.apple.com/design/human-interface-guidelines/color
    -->

    <!-- System Blue — primary accent (light / dark) -->
    <Color x:Key="Primary">#007AFF</Color>
    <Color x:Key="PrimaryDark">#0A84FF</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>

    <!-- System Red — used for destructive / recording-active states -->
    <Color x:Key="SystemRed">#FF3B30</Color>
    <Color x:Key="SystemRedDark">#FF453A</Color>

    <!-- Secondary / Tertiary semantic backgrounds -->
    <Color x:Key="Secondary">#F2F2F7</Color>
    <Color x:Key="SecondaryDark">#1C1C1E</Color>
    <Color x:Key="SecondaryDarkText">#0A84FF</Color>
    <Color x:Key="Tertiary">#E5E5EA</Color>
    <Color x:Key="TertiaryDark">#2C2C2E</Color>

    <!-- Grouped-list card backgrounds -->
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBackgroundDark">#1C1C1E</Color>
    <Color x:Key="GroupedBackground">#F2F2F7</Color>
    <Color x:Key="GroupedBackgroundDark">#000000</Color>

    <!-- Base -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#1C1C1E</Color>

    <!-- Apple System Grays (light-mode values) -->
    <Color x:Key="Gray100">#F2F2F7</Color>
    <Color x:Key="Gray200">#E5E5EA</Color>
    <Color x:Key="Gray300">#D1D1D6</Color>
    <Color x:Key="Gray400">#C7C7CC</Color>
    <Color x:Key="Gray500">#AEAEB2</Color>
    <Color x:Key="Gray600">#8E8E93</Color>
    <Color x:Key="Gray700">#636366</Color>
    <Color x:Key="Gray800">#3A3A3C</Color>
    <Color x:Key="Gray900">#2C2C2E</Color>
    <Color x:Key="Gray950">#1C1C1E</Color>

    <!-- Semantic label colors -->
    <Color x:Key="SecondaryLabel">#8E8E93</Color>
    <Color x:Key="SecondaryLabelDark">#EBEBF599</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

</ResourceDictionary>
